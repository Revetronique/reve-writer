{
  "mcpServers": {
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ntn_YOUR_NOTION_INTEGRATION_TOKEN\", \"Notion-Version\": \"2022-06-28\"}"
      }
    }
  }
}
